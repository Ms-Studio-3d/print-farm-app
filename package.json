{
  "name": "print-farm-app",
  "version": "1.0.0",
  "description": "Desktop app for 3D print farm management",
  "main": "main.js",
  "author": "Ms-Studio-3d",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.msstudio3d.printfarm",
    "productName": "Print Farm App",
    "files": [
      "index.html",
      "style.css",
      "app.js",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
