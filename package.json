{
  "name": "printing-business-manager",
  "version": "1.0.1",
  "description": "Desktop app for 3D printing business management",
  "main": "main.js",
  "author": "Ms-Studio-3d",
  "license": "MIT",
  "keywords": [
    "electron",
    "3d-printing",
    "business-manager",
    "desktop-app",
    "inventory",
    "sqlite"
  ],
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "rebuild": "electron-builder install-app-deps",
    "build": "electron-builder --dir",
    "dist": "electron-builder --win nsis --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:installer": "electron-builder --win nsis --publish never",
    "dist:portable": "electron-builder --win portable --publish never"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.msstudio3d.businessmanager",
    "productName": "Print Farm App",
    "asar": true,
    "artifactName": "${productName}-${version}-${target}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "index.html",
      "style.css",
      "app.js",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "!**/.git/**/*",
      "!**/.github/**/*",
      "!**/.cache/**/*",
      "!**/dist/**/*",
      "!**/build-installer.yml",
      "!**/*.md",
      "!**/*.map",
      "!**/*.log",
      "!**/test/**/*",
      "!**/tests/**/*",
      "!**/docs/**/*",
      "!**/coverage/**/*",
      "!**/.vscode/**/*",
      "!**/.idea/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Ms-Studio-3d"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "shortcutName": "Print Farm App",
      "uninstallDisplayName": "Print Farm App",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "publish": null
  }
}
